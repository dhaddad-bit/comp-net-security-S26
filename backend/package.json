{
  "name": "social-scheduler-backend",
  "version": "1.0.0",
  "main": "server.js",
  "scripts": {
    "build": "cd ../frontend && npm install && npm run build",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --config ./jest.config.cjs",
    "test:watch": "jest --config ./jest.config.cjs --watch",
    "test:ci": "jest --config ./jest.config.cjs --runInBand --ci",
    "test:algorithm": "npm --prefix ./algorithm test -- --config ./jest.config.mjs",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "start:prod": "NODE_ENV=production node server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:reload": "pm2 reload ecosystem.config.cjs --env production",
    "pm2:logs": "pm2 logs social-scheduler-backend"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "googleapis": "^105.0.0",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.1",
    "pg": "^8.11.3",
    "resend": "^6.9.1",
    "url": "^0.11.4"
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/node": "^24.7.2",
    "@types/pg": "^8.15.5",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "nodemon": "^3.0.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
